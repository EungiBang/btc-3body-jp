{
  "name": "btc-3body-outdoor-lite",
  "private": true,
  "version": "5.0.8L",
  "type": "module",
  "description": "BTC 3바디 AI분석기 (온라인 간편 버전)",
  "author": "Brain Training Center",
  "scripts": {
    "dev": "vite",
    "dev:root": "vite",
    "dev:lite": "npm run dev --prefix BT_3Body_Online_Lite",
    "dev:admin": "npm run dev --prefix BTC_Admin_Server",
    "dev:all": "concurrently \"npm run dev:root\" \"npm run dev:lite\" \"npm run dev:admin\"",
    "install:all": "npm install && npm install --prefix BT_3Body_Online_Lite && npm install --prefix BTC_Admin_Server",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "@mediapipe/selfie_segmentation": "^0.1.1675465747",
    "@mediapipe/tasks-vision": "^0.10.34",
    "@tensorflow-models/body-segmentation": "^1.0.2",
    "@tensorflow-models/pose-detection": "^2.1.3",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "@tensorflow/tfjs-converter": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "firebase": "^12.11.0",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "recharts": "^3.6.0",
    "remark-gfm": "^4.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@vercel/node": "^5.7.15",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "dotenv": "^17.4.2",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.10"
  }
}
